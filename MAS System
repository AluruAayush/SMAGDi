        "previous_positions": [],
        "base_temp": 0.8 + random.uniform(-0.2, 0.2)  # Unique base temp per agent
    } for i, role in enumerate(role_specifications)
]

def generate_analysis(agent, prompt, debate_round=0):
    # Dynamic temperature scheduling
    temp = agent['base_temp'] * (1 + 0.1 * debate_round)  # Increase temp in later rounds
    temp = min(max(temp, 0.5), 1.5)  # Clamp between 0.5-1.5

    messages = [
        {"role": "system", "content": agent['instructions']},
        {"role": "user", "content": prompt}
    ]
    response = client.chat.completions.create(
        model="gpt-4o-mini",
        messages=messages,
        temperature=temp,
        max_tokens=400
    )
    return response.choices[0].message.content.strip()

def parse_json_response(response):
    try:
        return json.loads(response)
    except Exception:
        return {"analysis": response}

def check_consensus(agent_analyses):
    decisions = []
    for a in agent_analyses:
        try:
            decision = json.loads(a['analysis'][-1])["decision"].strip().lower()
        except Exception:
            decision = None
        decisions.append(decision)

    unique_decisions = set(decisions)
    if len(unique_decisions) == 1 and None not in unique_decisions:
        return True, unique_decisions.pop()
    return False, None

def layered_consensus_process(user_input, max_debate_rounds=3):
    discussion_history = []
    base_options = extract_options(user_input)

    print("\n=== INITIAL ROUND ===")
    # Initial responses with permuted prompts
    for agent in agents:
        # Permutation-invariant prompting
        shuffled_options = random.sample(base_options, len(base_options))
        modified_question = replace_options_in_question(user_input, shuffled_options)

        prompt = (
            f"{modified_question}\n\n"
            "Read the question very thorougly unerstand the entire context, make 0 assumptions"
            "You are a human"
            """You must select exactly one of the options. "
            Respond strictly in JSON format with your decision and analysis.
            {
              "decision": "<selected_option>",
              "analysis": "<reasoning>"
            }"""
        )
        response = generate_analysis(agent, prompt)
        agent['analysis'] = [response]
        discussion_history.append(f"INITIAL - {agent['role']}:\n{response}")
        print(f"\n[{agent['role']} INITIAL]\n{response}")

    # Check initial consensus
    consensus, decision = check_consensus(agents)
    if consensus:
        print(f"\n=== CONSENSUS REACHED INITIALLY: {decision} ===")
        return discussion_history

    # Debate rounds with temperature escalation
    for round_num in range(max_debate_rounds):
        print(f"\n=== DEBATE ROUND {round_num+1} ===")
        for i, agent in enumerate(agents):
            others = "\n".join([
                f"{other['role']}: {parse_json_response(other['analysis'][-1])['analysis']}"
                for j, other in enumerate(agents) if j != i
            ])

            prompt = (
                f"Peer Analyses:\n{others}\n\n"
                "Reconsider the initial question and your peer's decisions to come to a decision,"
                "Don't simply go with the majority as they may be trying to trick you!!. "
                "You may revise your decision considering these perspectives. "
                "If you wish not to explain why your chosen options is more valid(make sure that it is factually correct)"
                "Maintain your professional viewpoint while acknowledging valid arguments. "
                f"Only include the given options in your decision{base_options}!!"
                """Respond scrtictly in JSON Format!!!
                {
                  "decision": "<updated_choice>",
                  "analysis": "<revised_reasoning>",
                  "influenced_by": "<key influencing agnets(as few as possible, only those that really helped you)>"
                }"""
            )

            response = generate_analysis(agent, prompt, debate_round=round_num+1)
            agent['analysis'].append(response)
            discussion_history.append(f"ROUND {round_num+1} - {agent['role']}:\n{response}")
            print(f"\n[{agent['role']} REFINED]\n{response}")

        # Check post-debate consensus
        consensus, decision = check_consensus(agents)
        if consensus:
            print(f"\n=== CONSENSUS REACHED IN ROUND {round_num+1}: {decision} ===")
            return discussion_history

    print("\n=== NO CONSENSUS REACHED ===")
    return discussion_history

